# Override the user's global `*.mod*` exclude — Go module files
# are not optional, they ARE the project. Without this negation,
# go.mod / build/go.mod / build/render-docs/go.mod all get dropped
# silently and CI's setup-go step fails with "go.mod does not exist".
!go.mod
!**/go.mod

# Build artifacts — produced by `make bundle`. Always regenerated
# from sources, never edited by hand.
/dist/
/server/dist/

# Compiled helper binaries built by `make` from build/manifest and
# build/pluginctl Go sources. Platform-specific; don't track them.
/build/bin/

# Rendered HTML for the docs + runbooks sites. Generated from
# docs/*.md and runbooks/*.md by build/render-docs on every bundle.
# Source of truth is the Markdown; do not commit the HTML.
/public/help/
/public/runbooks/

# Go test/coverage artifacts.
*.test
*.out
coverage.*
.cache/

# Editor + OS metadata.
.DS_Store
.vscode/
.idea/
*.swp
*.swo

# Local-only dev artifacts.
.env
.env.local
*.local

# Node modules (none today, but reserve in case a webapp is added).
node_modules/

# CodeQL CLI bundle + database (downloaded by `make install-codeql`).
# Both are large (~500MB+) and regenerated from scratch on each scan.
/build/codeql/
/build/codeql-db/

# Spurious go.sum CodeQL drops in server/ during database creation —
# the canonical go.sum lives at the repo root since the module is rooted there.
/server/go.sum

# Docker dev environment volumes (Mattermost + Postgres data).
/docker/postgres-data/
/docker/mattermost/

# Claude Code local settings (per-user, not shared).
.claude/settings.local.json
